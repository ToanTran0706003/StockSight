    "AllowedOrigins": [ "https://localhost:7000", "http://localhost:5000" ]
  },
  "StockIngestion": {
    "Enabled": true,
    "Symbols": [ "AAPL", "MSFT", "GOOGL", "TSLA", "AMZN" ],
    "PollInterval": "00:00:05"
  },
  "Hangfire": {
    "Enabled": true
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-5.5"
  }
}
