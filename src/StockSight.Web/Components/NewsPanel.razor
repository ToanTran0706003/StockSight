@inject HttpClient Http

<section class="news-panel">
    <div class="surface-header">
        <div>
            <span class="eyebrow">News</span>
            <h2>Sentiment tape</h2>
        </div>
        <span class="status-pill">@Symbol</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <p class="error">@error</p>
    }
    else if (loading)
    {
        <article>
            <div>
                <span class="skeleton skeleton-line"></span>
                <span class="skeleton skeleton-line skeleton-short"></span>
            </div>
            <span class="skeleton skeleton-line skeleton-short"></span>
        </article>
    }
    else if (articles.Count == 0)
    {
        <div class="empty-state">
            <strong>No market headlines yet.</strong>
            <span>Sentiment will appear when the feed returns articles for @Symbol.</span>
        </div>
    }
    else
    {
        @foreach (var article in articles)
        {
            <article>
                <div>
                    <strong>@article.Headline</strong>
                    <span class="status">@article.Source · @article.PublishedUtc.ToString("MMM dd HH:mm") UTC</span>
                </div>
                <span class="sentiment @article.Sentiment.ToLowerInvariant()">@SentimentIcon(article.Sentiment) @article.Sentiment @article.Score.ToString("N2")</span>
            </article>
        }
    }
</section>

@code {
    [Parameter]
    public string Symbol { get; set; } = "AAPL";

    private IReadOnlyList<NewsArticleDto> articles = Array.Empty<NewsArticleDto>();
    private bool loading = true;
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        error = null;

        try
        {
            articles = await Http.GetFromJsonAsync<IReadOnlyList<NewsArticleDto>>($"api/news/{Symbol}") ?? Array.Empty<NewsArticleDto>();
        }
        catch (Exception ex)
        {
            error = $"News feed unavailable: {ex.Message}";
            articles = Array.Empty<NewsArticleDto>();
        }
        finally
        {
            loading = false;
        }
    }

    private static string SentimentIcon(string sentiment)
        => sentiment.Equals("Bullish", StringComparison.OrdinalIgnoreCase) ? "▲"
            : sentiment.Equals("Bearish", StringComparison.OrdinalIgnoreCase) ? "▼"
            : "■";

    private record NewsArticleDto(
        string Symbol,
        string Headline,
        string Source,
        DateTime PublishedUtc,
        string Url,
        string Sentiment,
        decimal Score);
}
