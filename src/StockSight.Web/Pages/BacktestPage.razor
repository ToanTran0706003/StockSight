@page "/backtest"
@inject HttpClient Http

<PageTitle>Backtest - StockSight</PageTitle>

<section class="page-stack fade-in">
    <header class="page-head">
        <div class="page-title-group">
            <span class="eyebrow">Backtest lab</span>
            <h1>Strategy replay</h1>
            <p class="page-lead">Test a signal rule against historical candles before it becomes a portfolio decision.</p>
        </div>
        <span class="status-pill @(running ? "warn" : null)">@(running ? "Running" : "Ready")</span>
    </header>

    <section class="form-panel">
        <div class="backtest-form">
            <label>
                Symbol
                <input @bind="request.Symbol" />
            </label>
            <label>
                Strategy
                <select @bind="request.Strategy">
                    <option value="Macd">MACD</option>
                    <option value="SmaCrossover">SMA Crossover</option>
                    <option value="RsiReversal">RSI Reversal</option>
                </select>
            </label>
            <label>
                From
                <input type="date" @bind="request.From" />
            </label>
            <label>
                To
                <input type="date" @bind="request.To" />
            </label>
            <label>
                Initial capital
                <input type="number" min="100" step="100" @bind="request.InitialCapital" />
            </label>
            <button @onclick="RunAsync" disabled="@running">Run backtest</button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <p class="error">@error</p>
    }

    @if (result is null)
    {
        <section class="empty-state">
            <strong>No result loaded yet.</strong>
            <span>Run a strategy to generate metrics, an equity curve, and a trade log.</span>
        </section>
    }
    else
    {
        <section class="metrics-grid">
            <article><span class="status">Final value</span><strong class="metric-value">@Money(result.FinalValue)</strong></article>
            <article><span class="status">Return</span><strong class="metric-value @(result.TotalReturnPercent >= 0 ? "up" : "down")">@(result.TotalReturnPercent >= 0 ? "▲" : "▼") @result.TotalReturnPercent.ToString("N2")%</strong></article>
            <article><span class="status">Sharpe</span><strong class="metric-value">@result.SharpeRatio.ToString("N2")</strong></article>
            <article><span class="status">Max drawdown</span><strong class="metric-value down">▼ @result.MaxDrawdownPercent.ToString("N2")%</strong></article>
            <article><span class="status">Win rate</span><strong class="metric-value">@result.WinRate.ToString("N2")%</strong></article>
            <article><span class="status">Trades</span><strong class="metric-value">@result.TotalTrades</strong></article>
        </section>

        <section class="surface">
            <div class="surface-header">
                <div>
                    <span class="eyebrow">Equity curve</span>
                    <h2>@result.Strategy on @result.Symbol</h2>
                </div>
                <span class="status-pill">@result.From.ToString("yyyy-MM-dd") to @result.To.ToString("yyyy-MM-dd")</span>
            </div>
            <IndicatorPaneComponent
                Title="Equity"
                Subtitle="@($"{Money(result.InitialCapital)} starting capital")"
                Lines="equityLines" />
        </section>

        <section class="surface trade-log">
            <div class="surface-header">
                <h2>Trade log</h2>
                <span class="status-pill">@result.TotalTrades trades</span>
            </div>
            <div class="table-wrap">
                <table class="ticks">
                    <thead>
                        <tr><th>Date</th><th>Action</th><th>Price</th><th>Shares</th><th>Value</th><th>P&amp;L</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var trade in result.Trades)
                        {
                            <tr>
                                <td>@trade.Date.ToString("yyyy-MM-dd")</td>
                                <td>@trade.Action</td>
                                <td>@Money(trade.Price)</td>
                                <td>@trade.Shares.ToString("N4")</td>
                                <td>@Money(trade.Value)</td>
                                <td class="@(trade.PnL >= 0 ? "up" : "down")">@(trade.PnL >= 0 ? "▲" : "▼") @(trade.PnL?.ToString("N2") ?? "--")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</section>

@code {
    private BacktestForm request = new()
    {
        Symbol = "AAPL",
        Strategy = "Macd",
        From = DateTime.UtcNow.Date.AddYears(-1),
        To = DateTime.UtcNow.Date,
        InitialCapital = 10_000m
    };
    private BacktestResultDto? result;
    private IReadOnlyList<IndicatorPaneComponent.PaneLine> equityLines = Array.Empty<IndicatorPaneComponent.PaneLine>();
    private bool running;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await RunAsync();
    }

    private async Task RunAsync()
    {
        running = true;
        error = null;

        try
        {
            using var response = await Http.PostAsJsonAsync("api/backtest", request);
            if (!response.IsSuccessStatusCode)
            {
                error = await response.Content.ReadAsStringAsync();
                return;
            }

            result = await response.Content.ReadFromJsonAsync<BacktestResultDto>();
            equityLines = result?.EquityCurve is null
                ? Array.Empty<IndicatorPaneComponent.PaneLine>()
                :
                [
                    new("Equity", "#38bdf8", result.EquityCurve.Select(p => new IndicatorPoint(p.Date, p.Value)).ToArray())
                ];
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            running = false;
        }
    }

    private static string Money(decimal value) => value.ToString("C2");

    private class BacktestForm
    {
        public string Symbol { get; set; } = "AAPL";
        public string Strategy { get; set; } = "SmaCrossover";
        public DateTime From { get; set; }
        public DateTime To { get; set; }
        public decimal InitialCapital { get; set; }
    }

    private record BacktestResultDto(
        string Symbol,
        string Strategy,
        DateTime From,
        DateTime To,
        decimal InitialCapital,
        decimal FinalValue,
        decimal TotalReturnPercent,
        decimal SharpeRatio,
        decimal MaxDrawdownPercent,
        decimal WinRate,
        int TotalTrades,
        int WinningTrades,
        int LosingTrades,
        IReadOnlyList<EquityPointDto> EquityCurve,
        IReadOnlyList<TradeDto> Trades);

    private record EquityPointDto(DateTime Date, decimal Value);

    private record TradeDto(DateTime Date, string Action, decimal Price, decimal Shares, decimal Value, decimal? PnL);
}
