@page "/portfolio"
@implements IAsyncDisposable
@inject HttpClient Http
@inject NavigationManager Nav
@inject StockHubClient Hub

<PageTitle>Portfolio - StockSight</PageTitle>

<section class="page-stack fade-in">
    <header class="page-head">
        <div class="page-title-group">
            <span class="eyebrow">Portfolio</span>
            <h1>P&amp;L console</h1>
            <p class="page-lead">Create a paper portfolio, place simulated trades, and watch allocation and return drift with live prices.</p>
        </div>
        <span class="status-pill @(hubConnected ? "live" : "warn")">@(hubConnected ? "Live pricing" : "Pricing offline")</span>
    </header>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <p class="error">@error</p>
    }

    <section class="form-panel">
        <div class="surface-header">
            <h2>Create portfolio</h2>
            <span class="status">@portfolios.Count saved</span>
        </div>
        <div class="backtest-form">
            <label>Name<input @bind="newPortfolioName" /></label>
            <label>Initial cash<input type="number" min="1000" step="500" @bind="newInitialCash" /></label>
            <button @onclick="CreatePortfolioAsync">Create</button>
        </div>
    </section>

    @if (snapshot is null)
    {
        <section class="empty-state">
            <strong>No portfolio loaded.</strong>
            <span>Create one above to begin tracking positions.</span>
        </section>
    }
    else
    {
        <section class="metrics-grid">
            <article><span class="status">Total value</span><strong class="metric-value">@Money(snapshot.TotalValue)</strong></article>
            <article><span class="status">Cash</span><strong class="metric-value">@Money(snapshot.CashBalance)</strong></article>
            <article><span class="status">Market value</span><strong class="metric-value">@Money(snapshot.MarketValue)</strong></article>
            <article><span class="status">Total P&amp;L</span><strong class="metric-value @(snapshot.TotalPnL >= 0 ? "up" : "down")">@(snapshot.TotalPnL >= 0 ? "▲" : "▼") @Money(snapshot.TotalPnL)</strong></article>
            <article><span class="status">Return</span><strong class="metric-value @(snapshot.TotalPnLPercent >= 0 ? "up" : "down")">@(snapshot.TotalPnLPercent >= 0 ? "▲" : "▼") @snapshot.TotalPnLPercent.ToString("N2")%</strong></article>
        </section>

        <section class="form-panel">
            <div class="surface-header">
                <h2>Trade ticket</h2>
                <span class="status-pill">@snapshot.Name</span>
            </div>
            <div class="backtest-form">
                <label>Symbol<input @bind="trade.Symbol" /></label>
                <label>Shares<input type="number" min="0.0001" step="0.1" @bind="trade.Shares" /></label>
                <label>Price<input type="number" min="0.01" step="0.01" @bind="trade.Price" /></label>
                <button @onclick="BuyAsync">Buy</button>
                <button class="secondary-button" @onclick="SellAsync">Sell</button>
            </div>
        </section>

        @if (snapshot.Positions.Count == 0)
        {
            <section class="empty-state">
                <strong>No positions yet.</strong>
                <span>Use the trade ticket to add your first symbol.</span>
            </section>
        }
        else
        {
            <section class="allocation-list" aria-label="Portfolio allocation">
                @foreach (var position in snapshot.Positions)
                {
                    var width = snapshot.MarketValue == 0 ? 0 : position.MarketValue / snapshot.MarketValue * 100m;
                    <article>
                        <div><strong>@position.Symbol</strong><span class="num">@width.ToString("N1")%</span></div>
                        <div class="confidence-track"><div class="confidence-fill" style="width:@($"{Math.Clamp(width, 0, 100)}%")"></div></div>
                    </article>
                }
            </section>

            <section class="surface trade-log">
                <div class="surface-header">
                    <h2>Positions</h2>
                    <span class="status-pill">@snapshot.Positions.Count holdings</span>
                </div>
                <div class="table-wrap">
                    <table class="ticks">
                        <thead>
                            <tr><th>Symbol</th><th>Shares</th><th>Avg cost</th><th>Price</th><th>Value</th><th>P&amp;L</th><th>Return</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var p in snapshot.Positions)
                            {
                                <tr>
                                    <td>@p.Symbol</td>
                                    <td>@p.Shares.ToString("N4")</td>
                                    <td>@Money(p.AverageCost)</td>
                                    <td>@Money(p.CurrentPrice)</td>
                                    <td>@Money(p.MarketValue)</td>
                                    <td class="@(p.PnL >= 0 ? "up" : "down")">@(p.PnL >= 0 ? "▲" : "▼") @Money(p.PnL)</td>
                                    <td class="@(p.PnLPercent >= 0 ? "up" : "down")">@(p.PnLPercent >= 0 ? "▲" : "▼") @p.PnLPercent.ToString("N2")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }
</section>

@code {
    private List<PortfolioDto> portfolios = new();
    private PortfolioSnapshotDto? snapshot;
    private string newPortfolioName = "Growth Portfolio";
    private decimal newInitialCash = 10_000m;
    private string? error;
    private TradeForm trade = new() { Symbol = "AAPL", Shares = 1, Price = 250 };
    private bool hubConnected;

    protected override async Task OnInitializedAsync()
    {
        Hub.TickReceived += OnTick;
        try
        {
            await Hub.ConnectAsync();
            hubConnected = true;
        }
        catch
        {
            hubConnected = false;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        error = null;
        try
        {
            portfolios = await Http.GetFromJsonAsync<List<PortfolioDto>>("api/portfolio") ?? new();
            if (portfolios.Count == 0)
                await CreatePortfolioAsync();
            else
                await LoadSnapshotAsync(portfolios[0].Id);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Nav.NavigateTo("login");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task CreatePortfolioAsync()
    {
        var response = await Http.PostAsJsonAsync("api/portfolio", new { name = newPortfolioName, initialCash = newInitialCash });
        if (!response.IsSuccessStatusCode)
        {
            error = await response.Content.ReadAsStringAsync();
            return;
        }

        var created = await response.Content.ReadFromJsonAsync<PortfolioDto>();
        if (created is not null)
        {
            portfolios.Insert(0, created);
            await LoadSnapshotAsync(created.Id);
        }
    }

    private async Task BuyAsync() => await TradeAsync("buy");

    private async Task SellAsync() => await TradeAsync("sell");

    private async Task TradeAsync(string action)
    {
        if (snapshot is null)
            return;

        var response = await Http.PostAsJsonAsync($"api/portfolio/{snapshot.PortfolioId}/{action}", trade);
        if (!response.IsSuccessStatusCode)
        {
            error = await response.Content.ReadAsStringAsync();
            return;
        }

        await LoadSnapshotAsync(snapshot.PortfolioId);
    }

    private async Task LoadSnapshotAsync(Guid id)
    {
        snapshot = await Http.GetFromJsonAsync<PortfolioSnapshotDto>($"api/portfolio/{id}/pnl");
        await SubscribePositionsAsync();
    }

    private async Task SubscribePositionsAsync()
    {
        if (!hubConnected || snapshot is null)
            return;

        foreach (var symbol in snapshot.Positions.Select(p => p.Symbol).Distinct())
            await Hub.SubscribeAsync(symbol);
    }

    private void OnTick(StockTick tick)
    {
        if (snapshot?.Positions.Any(p => p.Symbol == tick.Symbol) != true)
            return;

        InvokeAsync(async () =>
        {
            await LoadSnapshotAsync(snapshot.PortfolioId);
            StateHasChanged();
        });
    }

    private static string Money(decimal value) => value.ToString("C2");

    private class TradeForm
    {
        public string Symbol { get; set; } = string.Empty;
        public decimal Shares { get; set; }
        public decimal Price { get; set; }
    }

    private record PortfolioDto(Guid Id, string Name, decimal InitialCash, decimal CashBalance);

    private record PortfolioSnapshotDto(
        Guid PortfolioId,
        string Name,
        decimal InitialCash,
        decimal CashBalance,
        decimal MarketValue,
        decimal TotalValue,
        decimal TotalPnL,
        decimal TotalPnLPercent,
        IReadOnlyList<PortfolioPositionDto> Positions);

    private record PortfolioPositionDto(
        string Symbol,
        decimal Shares,
        decimal AverageCost,
        decimal CurrentPrice,
        decimal MarketValue,
        decimal PnL,
        decimal PnLPercent);

    public async ValueTask DisposeAsync()
    {
        Hub.TickReceived -= OnTick;
        await Hub.DisposeAsync();
    }
}
