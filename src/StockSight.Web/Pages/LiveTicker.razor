@page "/ticker"
@implements IAsyncDisposable
@inject StockHubClient Hub

<PageTitle>Live Ticker</PageTitle>

<section class="page-stack fade-in">
    <header class="page-head">
        <div class="page-title-group">
            <span class="eyebrow">Live ticker</span>
            <h1>Realtime tape</h1>
            <p class="page-lead">Subscribe to a symbol and watch incoming ticks stack into a compact market tape.</p>
        </div>
        <span class="status-pill @(connected ? "live" : "warn")">@statusText</span>
    </header>

    <section class="form-panel">
        <div class="controls">
            <input @bind="symbol" placeholder="Symbol e.g. AAPL" aria-label="Symbol to subscribe" />
            <button @onclick="SubscribeAsync" disabled="@(!connected)">Subscribe</button>
            <span class="status">Newest ticks appear first.</span>
        </div>
    </section>

    @if (ticks.Count == 0)
    {
        <section class="empty-state">
            <strong>No ticks received yet.</strong>
            <span>Subscribe to a symbol to start streaming realtime updates.</span>
        </section>
    }
    else
    {
        <section class="surface trade-log">
            <div class="surface-header">
                <h2>Tick stream</h2>
                <span class="status-pill">@ticks.Count rows</span>
            </div>
            <div class="table-wrap">
                <table class="ticks">
                    <thead>
                        <tr><th>Symbol</th><th>Price</th><th>Change</th><th>%</th><th>Time (UTC)</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in ticks)
                        {
                            <tr>
                                <td>@t.Symbol</td>
                                <td>@t.Price.ToString("N2")</td>
                                <td class="@(t.Change >= 0 ? "up" : "down")">@(t.Change >= 0 ? "▲" : "▼") @t.Change.ToString("N2")</td>
                                <td class="@(t.Change >= 0 ? "up" : "down")">@(t.Change >= 0 ? "▲" : "▼") @t.ChangePercent.ToString("N2")%</td>
                                <td>@t.TimestampUtc.ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</section>

@code {
    private string symbol = "AAPL";
    private bool connected;
    private string statusText = "Connecting…";
    private readonly List<StockTick> ticks = new();

    protected override async Task OnInitializedAsync()
    {
        Hub.TickReceived += OnTick;
        try
        {
            await Hub.ConnectAsync();
            connected = true;
            statusText = "Connected";
        }
        catch (Exception ex)
        {
            statusText = $"Connection failed: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task SubscribeAsync()
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return;
        await Hub.SubscribeAsync(symbol.Trim().ToUpperInvariant());
        statusText = $"Subscribed to {symbol.ToUpperInvariant()}";
    }

    private void OnTick(StockTick tick)
    {
        InvokeAsync(() =>
        {
            ticks.Insert(0, tick);
            if (ticks.Count > 50)
                ticks.RemoveAt(ticks.Count - 1);
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        Hub.TickReceived -= OnTick;
        await Hub.DisposeAsync();
    }
}
