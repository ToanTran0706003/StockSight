@page "/watchlist"
@implements IAsyncDisposable
@inject HttpClient Http
@inject StockHubClient Hub
@inject AuthStateProvider Auth

<PageTitle>Watchlist - StockSight</PageTitle>

<section class="page-stack fade-in">
    <header class="page-head">
        <div class="page-title-group">
            <span class="eyebrow">Watchlist</span>
            <h1>Live quote board</h1>
            <p class="page-lead">Track symbols, stream updates over SignalR, and open a full chart when a move deserves more context.</p>
        </div>
        <span class="status-pill @(connected ? "live" : "warn")">@statusText</span>
    </header>

    <section class="form-panel">
        <div class="controls">
            <input @bind="newSymbol" placeholder="Symbol e.g. NVDA" aria-label="Symbol to add" />
            <button @onclick="AddSymbolAsync" disabled="@(!connected)">Add symbol</button>
            <span class="status">Default list syncs with your account when signed in.</span>
        </div>
    </section>

    @if (symbols.Count == 0)
    {
        <section class="empty-state">
            <strong>No symbols yet.</strong>
            <span>Add a ticker above to start streaming quotes.</span>
        </section>
    }
    else
    {
        <section class="watchlist-grid" aria-label="Live quote cards">
            @foreach (var symbol in symbols)
            {
                var tick = latest.GetValueOrDefault(symbol);
                <article class="quote-card fade-in">
                    <div class="quote-card-head">
                        <div>
                            <h2 class="quote-symbol"><NavLink href="@($"stock/{symbol}")">@symbol</NavLink></h2>
                            <span class="status">Live quote</span>
                        </div>
                        <button class="link-button" @onclick="() => RemoveSymbolAsync(symbol)">Remove</button>
                    </div>

                    @if (tick is null)
                    {
                        <span class="skeleton skeleton-price"></span>
                        <span class="skeleton skeleton-line skeleton-short"></span>
                    }
                    else
                    {
                        <div>
                            <strong class="price">@tick.Price.ToString("N2")</strong>
                            <span class="change-pill @(tick.Change >= 0 ? "up" : "down")">
                                @(tick.Change >= 0 ? "▲" : "▼") @tick.Change.ToString("N2") (@tick.ChangePercent.ToString("N2")%)
                            </span>
                        </div>
                        <div class="quote-card-foot">
                            <span class="status">@tick.TimestampUtc.ToString("HH:mm:ss") UTC</span>
                            <NavLink class="status-pill" href="@($"stock/{symbol}")">Open chart</NavLink>
                        </div>
                    }
                </article>
            }
        </section>
    }
</section>

@code {
    private readonly List<string> symbols = new() { "AAPL", "MSFT", "GOOGL", "TSLA", "AMZN" };
    private readonly Dictionary<string, StockTick> latest = new();
    private string newSymbol = "NVDA";
    private bool connected;
    private string statusText = "Connecting...";

    protected override async Task OnInitializedAsync()
    {
        Hub.TickReceived += OnTick;

        try
        {
            await Hub.ConnectAsync();
            connected = true;
            statusText = "Connected";

            await LoadWatchlistAsync();
            foreach (var symbol in symbols.ToArray())
                await SubscribeAndLoadAsync(symbol);
        }
        catch (Exception ex)
        {
            statusText = $"Connection failed: {ex.Message}";
        }
    }

    private async Task AddSymbolAsync()
    {
        var symbol = Clean(newSymbol);
        if (symbol.Length == 0 || symbols.Contains(symbol))
            return;

        if (Auth.CurrentUser is not null)
        {
            var response = await Http.PostAsync($"api/watchlist/{symbol}", null);
            if (!response.IsSuccessStatusCode)
            {
                statusText = await response.Content.ReadAsStringAsync();
                return;
            }
        }

        symbols.Add(symbol);
        await SubscribeAndLoadAsync(symbol);
        newSymbol = string.Empty;
    }

    private async Task RemoveSymbolAsync(string symbol)
    {
        if (Auth.CurrentUser is not null)
            await Http.DeleteAsync($"api/watchlist/{symbol}");

        symbols.Remove(symbol);
        latest.Remove(symbol);
    }

    private async Task LoadWatchlistAsync()
    {
        if (Auth.CurrentUser is null)
            return;

        try
        {
            var items = await Http.GetFromJsonAsync<IReadOnlyList<WatchlistItem>>("api/watchlist");
            if (items is { Count: > 0 })
            {
                symbols.Clear();
                symbols.AddRange(items.Select(i => Clean(i.Symbol)));
            }
        }
        catch
        {
            statusText = "Using local watchlist";
        }
    }

    private async Task SubscribeAndLoadAsync(string symbol)
    {
        await Hub.SubscribeAsync(symbol);

        try
        {
            var tick = await Http.GetFromJsonAsync<StockTick>($"api/stocks/{symbol}/quote");
            if (tick is not null)
                latest[symbol] = tick;
        }
        catch
        {
            latest.Remove(symbol);
        }

        StateHasChanged();
    }

    private void OnTick(StockTick tick)
    {
        InvokeAsync(() =>
        {
            var symbol = Clean(tick.Symbol);
            if (!symbols.Contains(symbol))
                symbols.Add(symbol);

            latest[symbol] = tick;
            StateHasChanged();
        });
    }

    private static string Clean(string symbol) => symbol.Trim().ToUpperInvariant();

    public async ValueTask DisposeAsync()
    {
        Hub.TickReceived -= OnTick;
        await Hub.DisposeAsync();
    }
}
