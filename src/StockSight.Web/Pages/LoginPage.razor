@page "/login"
@inject AuthStateProvider Auth
@inject NavigationManager Nav

<PageTitle>Login - StockSight</PageTitle>

<section class="auth-shell fade-in">
    <div class="page-title-group">
        <span class="eyebrow">Secure session</span>
        <h1>Return to your market workspace.</h1>
        <p class="page-lead">Demo credentials are prefilled so you can inspect watchlists, portfolios, alerts, and chart workflows quickly.</p>
    </div>

    <div class="page-stack">
        <section class="auth-panel">
            <div>
                <span class="eyebrow">Login</span>
                <h2>Access StockSight</h2>
            </div>
            <label>Email<input @bind="email" type="email" autocomplete="email" /></label>
            <label>Password<input @bind="password" type="password" autocomplete="current-password" /></label>
            <button @onclick="LoginAsync" disabled="@busy">@(busy ? "Signing in" : "Login")</button>
            <NavLink href="register">Create account</NavLink>
        </section>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <p class="error">@error</p>
        }
    </div>
</section>

@code {
    private string email = "demo@stocksight.local";
    private string password = "demo";
    private bool busy;
    private string? error;

    private async Task LoginAsync()
    {
        busy = true;
        error = null;
        try
        {
            await Auth.LoginAsync(email, password);
            Nav.NavigateTo("watchlist");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
