@page "/login"
@inject AuthStateProvider Auth
@inject NavigationManager Nav

<PageTitle>Login - StockSight</PageTitle>

<h1>Login</h1>

<section class="auth-panel">
    <label>Email<input @bind="email" type="email" /></label>
    <label>Password<input @bind="password" type="password" /></label>
    <button @onclick="LoginAsync" disabled="@busy">Login</button>
    <NavLink href="register">Create account</NavLink>
</section>

@if (!string.IsNullOrWhiteSpace(error))
{
    <p class="error">@error</p>
}

@code {
    private string email = "demo@stocksight.local";
    private string password = "demo";
    private bool busy;
    private string? error;

    private async Task LoginAsync()
    {
        busy = true;
        error = null;
        try
        {
            await Auth.LoginAsync(email, password);
            Nav.NavigateTo("watchlist");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
