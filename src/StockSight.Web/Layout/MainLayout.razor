@inherits LayoutComponentBase
@inject AuthStateProvider Auth
@inject NavigationManager Nav

<div class="page">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="topbar">
        <NavLink class="brand" href="" Match="NavLinkMatch.All" aria-label="StockSight home">
            <span class="brand-mark" aria-hidden="true">S</span>
            <span>StockSight</span>
        </NavLink>
        <nav aria-label="Primary navigation">
            <NavLink href="" Match="NavLinkMatch.All">Home</NavLink>
            <NavLink href="watchlist">Watchlist</NavLink>
            <NavLink href="stock/AAPL">Chart</NavLink>
            <NavLink href="backtest">Backtest</NavLink>
            <NavLink href="portfolio">Portfolio</NavLink>
            <NavLink href="alerts">Alerts</NavLink>
            <NavLink href="ticker">Live Ticker</NavLink>
        </nav>
        <div class="auth-nav">
            <AuthorizeView>
                <Authorized>
                    <span class="auth-user">@context.User.Identity?.Name</span>
                    <button @onclick="Logout">Logout</button>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="login">Login</NavLink>
                    <NavLink href="register">Register</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>
    <main id="main-content" class="app-main">
        @Body
    </main>
</div>

@code {
    private void Logout()
    {
        Auth.Logout();
        Nav.NavigateTo("login");
    }
}
